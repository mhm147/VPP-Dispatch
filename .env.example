# Copy this file to .env and paste your token once ENTSO-E grants API access.
#
# ENTSO-E does NOT show the token button until you complete these steps:
#   1. Register (free): https://transparency.entsoe.eu/ -> Sign In -> Register
#   2. Verify your email (click the link they send you)
#   3. Email transparency@entsoe.eu
#        Subject: RESTful API access
#        Body:    the email address you registered with
#   4. Wait for approval (usually within 3 working days)
#   5. Log in -> My Account Settings -> Generate token
#
ENTSOE_API_KEY=your-token-here
